{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "chmod +x mvnw 2>/dev/null; mvn clean package -DskipTests -B"
  },
  "deploy": {
    "startCommand": "java $JAVA_OPTS -jar target/AIStudyAssistant-1.0.0.jar",
    "healthcheckPath": "/actuator/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
